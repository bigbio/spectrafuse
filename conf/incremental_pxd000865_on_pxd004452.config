/*
 * Incremental: Add PXD000865 (5M PSMs, LTQ Orbitrap Elite) onto
 * PXD004452's cluster DB (5.5M PSMs, Q Exactive).
 *
 * Uses --skip_instrument because the two datasets have different instruments.
 * This clusters all instruments together under "all_instruments" so the
 * incremental merge has a matching partition to merge into.
 *
 * NOTE: The PXD004452 full run must also use --skip_instrument (or the
 * cluster DB directory layout must match). If PXD004452 was run with a
 * specific instrument, update existing_cluster_db path accordingly.
 *
 * Run:
 *   cd /srv/data/spectrafuse/repo-clone
 *   nextflow run main.nf -c conf/incremental_pxd000865_on_pxd004452.config \
 *     -profile docker -resume
 */

params {
    mode               = 'incremental'
    existing_cluster_db = '/srv/data/spectrafuse/test_output/nf_pxd004452_5m/cluster_db'

    parquet_dir        = '/srv/data/spectrafuse/test_input/pxd000865'
    outdir             = '/srv/data/spectrafuse/test_output/nf_incremental_pxd000865_on_pxd004452'
    default_species    = 'Homo sapiens'
    default_instrument = 'all_instruments'
    skip_instrument    = true

    // Resources
    max_memory = '28.GB'
    max_cpus   = 8
    max_time   = '12.h'

    // m/z windowing
    mz_window_size    = 300
    mz_window_overlap = 1.0

    // MaRaCluster
    cluster_threshold            = 30
    maracluster_pvalue_threshold = -10.0
    maracluster_precursor_tolerance = 20.0

    // Consensus
    strategytype = 'best'
}

process {
    withName: '.*PARQUET_TO_DAT'             { container = 'pyspectrafuse:local' }
    withName: '.*SPLIT_MZ_WINDOWS'           { container = 'pyspectrafuse:local' }
    withName: '.*MERGE_MZ_WINDOWS'           { container = 'pyspectrafuse:local' }
    withName: '.*BUILD_CLUSTER_DB'           { container = 'pyspectrafuse:local' }
    withName: '.*GENERATE_MSP_FORMAT.*'      { container = 'pyspectrafuse:local' }
    withName: '.*CONCAT_DAT_FILES'           { container = 'pyspectrafuse:local' }
    withName: '.*EXTRACT_REPS_DAT'           { container = 'pyspectrafuse:local' }
    withName: '.*RESOLVE_AND_MERGE.*'        { container = 'pyspectrafuse:local'; memory = '16.GB' }

    withName: '.*RUN_MARACLUSTER_DAT' { memory = '16.GB' }
}

docker.runOptions = '--entrypoint ""'
docker.registry = ''
