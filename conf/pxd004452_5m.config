/*
 * PXD004452: 5.50M PSMs, Homo sapiens, Q Exactive
 *
 * Full mode with m/z windowing. Largest dataset by PSM count in the collection.
 * Different instrument than PXD000865, so this is an independent partition.
 *
 * Expected sizes:
 *   .dat output:  ~550 MB (5.5M × 100 bytes)
 *   Cluster DB:   ~1-2 GB
 *   Pipeline time: ~30-60 min (depends on MaRaCluster parallelism)
 *
 * Run:
 *   cd /srv/data/spectrafuse/repo-clone
 *   nextflow run main.nf -c conf/pxd004452_5m.config -profile docker \
 *     -resume
 */

params {
    parquet_dir        = '/srv/data/spectrafuse/test_input/pxd004452'
    outdir             = '/srv/data/spectrafuse/test_output/nf_pxd004452_5m'
    default_species    = 'Homo sapiens'
    default_instrument = 'all_instruments'
    skip_instrument    = true

    // Resources — 32 GB RAM, 8 CPUs available
    max_memory = '28.GB'
    max_cpus   = 8
    max_time   = '12.h'

    // m/z windowing — 300 Da windows for good parallelism at this scale
    mz_window_size    = 300
    mz_window_overlap = 1.0

    // MaRaCluster
    cluster_threshold            = 30
    maracluster_pvalue_threshold = -10.0
    maracluster_precursor_tolerance = 20.0

    // Consensus
    strategytype = 'best'
}

process {
    // Use local Docker image (not yet published to ghcr.io)
    withName: '.*PARQUET_TO_DAT'             { container = 'pyspectrafuse:local' }
    withName: '.*SPLIT_MZ_WINDOWS'           { container = 'pyspectrafuse:local' }
    withName: '.*MERGE_MZ_WINDOWS'           { container = 'pyspectrafuse:local' }
    withName: '.*BUILD_CLUSTER_DB'           { container = 'pyspectrafuse:local'; memory = '28.GB'; maxForks = 1 }
    withName: '.*GENERATE_MSP_FORMAT.*'      { container = 'pyspectrafuse:local' }
    withName: '.*CONCAT_DAT_FILES'           { container = 'pyspectrafuse:local' }
    withName: '.*EXTRACT_REPS_DAT'           { container = 'pyspectrafuse:local' }
    withName: '.*RESOLVE_AND_MERGE.*'        { container = 'pyspectrafuse:local' }

    // MaRaCluster uses the biocontainers image — no override needed
    withName: '.*RUN_MARACLUSTER_DAT' { memory = '16.GB' }
}

docker.runOptions = '--entrypoint ""'
docker.registry = ''
