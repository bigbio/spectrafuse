/*
 * End-to-end test configuration for spectrafuse pipeline.
 * Uses local pyspectrafuse:local Docker image.
 * Test data: PXD014877 (Mycoplasmen, 3608 PSMs, QPX format)
 */

params {
    parquet_dir        = '/srv/data/spectrafuse/test_input/pxd014877'
    outdir             = '/srv/data/spectrafuse/test_output/nf_pxd014877'
    default_species    = 'Mycoplasmen'
    default_instrument = 'Q Exactive HF-X'
    max_memory         = '8.GB'
    max_cpus           = 4
    max_time           = '2.h'
}

process {
    withName: '.*PARQUET_TO_DAT'             { container = 'pyspectrafuse:local' }
    withName: '.*SPLIT_MZ_WINDOWS'           { container = 'pyspectrafuse:local' }
    withName: '.*MERGE_MZ_WINDOWS'           { container = 'pyspectrafuse:local' }
    withName: '.*BUILD_CLUSTER_DB'           { container = 'pyspectrafuse:local' }
    withName: '.*GENERATE_MSP_FORMAT.*'      { container = 'pyspectrafuse:local' }
    withName: '.*CONCAT_DAT_FILES'           { container = 'pyspectrafuse:local' }
    withName: '.*EXTRACT_REPS_DAT'           { container = 'pyspectrafuse:local' }
    withName: '.*RESOLVE_AND_MERGE.*'        { container = 'pyspectrafuse:local' }
}

// Running as root — no user mapping needed
docker.runOptions = '--entrypoint ""'

// Override default quay.io registry — local images don't need a registry prefix
docker.registry = ''
