/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config for the EMBL-EBI Codon cluster (SLURM login nodes)
    Modelled on bigbio/quantms/conf/pride_codon_slurm.config
    Based on     https://github.com/nf-core/configs/blob/master/conf/ebi_codon_slurm.config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_contact     = "Yasset Perez-Riverol"
    config_profile_description = "EMBL-EBI Codon cluster (SLURM login nodes) — PRIDE reanalysis"
    config_profile_url         = "https://www.ebi.ac.uk/"
}

// Force Singularity + turn off every other container engine for this profile.
conda.enabled        = false
docker.enabled       = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

singularity {
    enabled     = true
    // Large images (>1 GB) exceed the default 20-minute pull timeout.
    pullTimeout = "3 hours"
    // The shared filesystem is bind-mounted explicitly; no need for auto-mount.
    autoMounts  = false
    runOptions  = '-B /hps/nobackup/juan/pride/reanalysis:/hps/nobackup/juan/pride/reanalysis'
    cacheDir    = "/hps/nobackup/juan/pride/reanalysis/singularity/"
}

process {
    // Shared filesystem latency can cause transient stage-in failures — retry
    // aggressively rather than failing the whole partition.
    maxRetries    = 30
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 1 + 9 + 134 + 97 + 0 + Integer.MAX_VALUE) ? "retry" : "terminate" }
    cache         = "lenient"
    afterScript   = "sleep 60"

    resourceLimits = [
        memory: 1900.GB,
        cpus:   48,
        time:   30.d
    ]

    // Heavy step on very large charges — scale with cluster count seen so far.
    withName: BUILD_CLUSTER_DB {
        memory = { 32.GB * task.attempt }
        cpus   = { 8 * task.attempt }
        time   = { 24.h * task.attempt }
    }
    withName: MERGE_INTO_EXISTING_DB {
        memory = { 32.GB * task.attempt }
        cpus   = { 8 * task.attempt }
        time   = { 24.h * task.attempt }
    }
    // MaRaCluster per m/z window — parallelism comes from many jobs, not size.
    withName: RUN_MARACLUSTER_DAT {
        memory = { 16.GB * task.attempt }
        cpus   = { 4 * task.attempt }
        time   = { 12.h * task.attempt }
    }
    withName: GENERATE_MSP_FORMAT {
        memory = { 16.GB * task.attempt }
        cpus   = { 4 * task.attempt }
        time   = { 12.h * task.attempt }
    }
}

executor {
    name              = "slurm"
    queueSize         = 2000
    submitRateLimit   = "10/1sec"
    exitReadTimeout   = "30 min"
    queueGlobalStatus = true
    jobName           = {
        task.name
            .replace("[", "(")
            .replace("]", ")")
            .replace(" ", "_")
    }
}
